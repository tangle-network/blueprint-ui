{
  "name": "@tangle-network/blueprint-ui",
  "version": "0.1.1",
  "description": "Shared blueprint UI components, hooks, and contract utilities for Tangle Network apps",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tangle-network/blueprint-ui.git"
  },
  "homepage": "https://github.com/tangle-network/blueprint-ui",
  "bugs": {
    "url": "https://github.com/tangle-network/blueprint-ui/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "package.json",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "import": "./dist/components.js",
      "types": "./dist/components.d.ts",
      "default": "./dist/components.js"
    },
    "./preset": {
      "import": "./dist/preset.js",
      "types": "./dist/preset.d.ts",
      "default": "./dist/preset.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsup && node scripts/build-styles.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@nanostores/react": "^0.7.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.2.0",
    "blo": "^2.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "framer-motion": "^12.0.0",
    "nanostores": "^0.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.2.0",
    "viem": "^2.31.0",
    "wagmi": "^3.3.0"
  },
  "peerDependenciesMeta": {},
  "devDependencies": {
    "@tanstack/react-query": "^5.90.16",
    "@nanostores/react": "^1.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "@iconify-json/ph": "^1.2.2",
    "blo": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "nanostores": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tsup": "^8.5.0",
    "typescript": "^5.5.2",
    "unocss": "^66.5.4",
    "unocss-preset-animations": "^1.1.1",
    "viem": "^2.46.2",
    "wagmi": "^3.5.0"
  }
}
